{
  "manifest_version": 3,
  "name": "LinkedIn Auto Connect Pro",
  "version": "1.0.0",
  "description": "Automatize conexões no LinkedIn com mensagens personalizadas e controle total",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "connect-addon@downloadzz.com",
      "strict_min_version": "109.0"
    }
  }
}

